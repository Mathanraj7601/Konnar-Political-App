{
	"info": {
		"name": "Admin Panel - Users API",
		"description": "APIs for managing Admin/Staff Users separately from Mobile App Members.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Create Admin User",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"mobile_number\": \"9988776655\",\n  \"role\": \"ADMIN\",\n  \"status\": \"ACTIVE\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/users",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users"
					]
				}
			}
		},
		{
			"name": "2. List Admin Users",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/users",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users"
					]
				}
			}
		},
		{
			"name": "3. Update Admin User (Role/Status)",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"role\": \"USER\",\n  \"status\": \"BANNED\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/users/:id",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users",
						":id"
					],
					"variable": [
						{
							"key": "id",
							"value": "PASTE_USER_ID_HERE"
						}
					]
				}
			}
		},
		{
			"name": "4. Toggle Active/Inactive",
			"request": {
				"method": "PATCH",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"is_active\": false\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/users/:id/status",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users",
						":id",
						"status"
					],
					"variable": [
						{
							"key": "id",
							"value": "PASTE_USER_ID_HERE"
						}
					]
				}
			}
		},
		{
			"name": "5. Delete Admin User",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/users/:id",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"users",
						":id"
					],
					"variable": [
						{
							"key": "id",
							"value": "PASTE_USER_ID_HERE"
						}
					]
				}
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:4000",
			"type": "string"
		}
	]
}

			"name": "1. Authentication",
			"item": [
				{
					"name": "Check User Exists",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mobile\": \"9876543210\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/check-user",
							"host": ["{{base_url}}"],
							"path": ["auth", "check-user"]
						}
					}
				},

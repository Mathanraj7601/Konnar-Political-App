							"raw": "{\n  \"name\": \"Arjun Kumar\",\n  \"mobile\": \"9876543210\",\n  \"dob\": \"2001-03-15\",\n  \"gender\": \"Male\",\n  \"blood_group\": \"O+\",\n  \"father_name\": \"R. Sekar\",\n  \"voter_id\": \"DEF1234567\",\n  \"aadhaar_number\": \"123456789012\",\n  \"street\": \"123 Main Street\",\n  \"door_number\": \"45A\",\n  \"village\": \"Kanchipuram\",\n  \"union\": \"Kanchipuram Union\",\n  \"district\": \"Kanchipuram\",\n  \"state\": \"Tamil Nadu\",\n  \"pincode\": \"631501\",\n  \"taluk\": \"Kanchipuram Taluk\",\n  \"verification_token\": \"mock-verify-9876543210\"\n}"

								"members"
							]
						}
					}
				}
			]
		},
		{
			"name": "Announcements",
			"item": [
				{
					"name": "1. List Announcements",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/announcements",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"announcements"
							]
						}
					}
				},
				{
					"name": "2. Create Announcement",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Community Meetup\",\n    \"description\": \"Join us for the monthly gathering this Saturday at the local hall.\",\n    \"date\": \"MAY 25, 2024\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/announcements",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"announcements"
							]
						}
					}
				},
				{
					"name": "3. Edit Announcement",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Community Meetup (Updated)\",\n    \"description\": \"The venue has changed to the central park. See you there!\",\n    \"date\": \"MAY 26, 2024\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/announcements/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"announcements",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "ENTER_ANNOUNCEMENT_ID_HERE",
									"description": "UUID of the announcement to update"
								}
							]
						}
					}
				},
				{
					"name": "4. Delete Announcement",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/announcements/:id",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"announcements",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "ENTER_ANNOUNCEMENT_ID_HERE",
									"description": "UUID of the announcement to delete"
								}
							]
						}
					}
				}
			]
		}
	],
